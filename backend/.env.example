# Project Hype — Backend Environment Variables
# Copy to .env and fill in your keys

# PostgreSQL connection string (provided automatically on Railway)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ExchangeRate-API v6 key — https://www.exchangerate-api.com/
# Free tier: 1,500 requests/month, 160+ currencies
FX_API_KEY=

# SendGrid API key for Catalyst Score email alerts
# https://sendgrid.com — free tier: 100 emails/day
SENDGRID_API_KEY=

# Verified sender address in your SendGrid account
ALERT_FROM_EMAIL=alerts@projecthype.io

# Public frontend URL (used in alert email links)
APP_URL=https://frontend-production-3fb7.up.railway.app

# Comma-separated list of allowed frontend origins for CORS.
# Defaults to local dev if not set.
# In production set to your Railway frontend URL:
#   ALLOWED_ORIGINS=https://your-frontend.up.railway.app
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
