# Project Hype — Environment Variables
# Copy to .env and fill in your keys

# ExchangeRate-API v6 key — https://www.exchangerate-api.com/
# Free tier: 1,500 requests/month, 160+ currencies
# Without this key, all 40 currencies fall back to hardcoded rates
FX_API_KEY=

# NewsAPI.org key — https://newsapi.org/
# Free tier: 100 requests/day, developer use
# Without this key, analyst-written mock headlines are served instead
NEWSAPI_KEY=
