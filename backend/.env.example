# Project Hype — Backend Environment Variables
# Copy to .env and fill in your keys

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (provided automatically on Railway)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── FX Rates (primary) ────────────────────────────────────────────────────────
# Open Exchange Rates — industry standard for production FX applications
# Broader frontier currency coverage than alternatives
# Free tier: 1,000 requests/month — https://openexchangerates.org/signup/free
# Paid tiers from $12/month for more requests + features
OPEN_EXCHANGE_RATES_APP_ID=

# ── FX Rates (secondary fallback) ────────────────────────────────────────────
# ExchangeRate-API v6 — used if OXR call fails
# Free tier: 1,500 requests/month — https://www.exchangerate-api.com/
FX_API_KEY=

# ── Sentiment Scoring ─────────────────────────────────────────────────────────
# Anthropic Claude API — used for geopolitically-aware headline sentiment scoring
# Replaces VADER for exotic/frontier currency context understanding
# Get key at: https://console.anthropic.com/
# Model used: claude-haiku-4-5-20251001 (fast and cheap — ~$0.001 per scoring run)
ANTHROPIC_API_KEY=

# ── Email Alerts ──────────────────────────────────────────────────────────────
# SendGrid API key for Catalyst Score email alerts
# https://sendgrid.com — free tier: 100 emails/day
SENDGRID_API_KEY=

# Verified sender address in your SendGrid account
ALERT_FROM_EMAIL=alerts@projecthype.io

# ── App Config ────────────────────────────────────────────────────────────────
# Public frontend URL (used in alert email links)
APP_URL=https://frontend-production-3fb7.up.railway.app

# Comma-separated list of allowed frontend origins for CORS.
# Defaults to local dev if not set.
# In production set to your Railway frontend URL:
#   ALLOWED_ORIGINS=https://your-frontend.up.railway.app
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
